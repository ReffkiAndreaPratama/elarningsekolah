PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=school_elearning

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# School Location (GPS center point)
SCHOOL_LAT=14.5995
SCHOOL_LNG=120.9842
SCHOOL_RADIUS_METERS=200

# QR Code
QR_EXPIRY_MINUTES=10

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
